<script>
const fd={};
const TOTAL=5;

function pick(btn,field,val,next){
  btn.closest('.opts').querySelectorAll('.opt').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  fd[field]=val;
  setTimeout(()=>goStep(next),260);
}

function goStep(n){
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  const t=document.getElementById('s'+n);
  if(t) t.classList.add('active');

  // progress line
  document.getElementById('progFill').style.width=((n-1)/TOTAL*100)+'%';

  // dots
  for(let i=1;i<=TOTAL;i++){
    const c=document.getElementById('dc'+i);
    const l=document.getElementById('dl'+i);
    if(!c) continue;
    c.classList.remove('active','done');
    l.classList.remove('active');
    if(i<n){ c.classList.add('done'); c.textContent='✓'; }
    else if(i===n){ c.classList.add('active'); l.classList.add('active'); }
  }
}

function doSubmit(){
  const nm=document.getElementById('iName').value.trim();
  const ph=document.getElementById('iPhone').value.trim();
  const ck=document.getElementById('chk').checked;
  if(!nm){alert('이름을 입력해 주세요.');return}
  if(!ph){alert('연락처를 입력해 주세요.');return}
  if(!ck){alert('개인정보 수집·이용에 동의해 주세요.');return}
  fd.name=nm; fd.phone=ph;
  console.log('Submitted:',fd);

  document.querySelectorAll('.step').forEach(s=>s.style.display='none');
  document.querySelector('.prog-wrap').style.display='none';
  document.getElementById('phAlt').style.display='none';
  document.querySelector('.form-top-sub').textContent='신청 완료 ✓';
  document.getElementById('successScr').style.display='block';
}

function scrollForm(){
  document.getElementById('formCard').scrollIntoView({behavior:'smooth',block:'center'});
}

// phone format
document.getElementById('iPhone').addEventListener('input',function(){
  let v=this.value.replace(/\D/g,'');
  if(v.length>=8) v=v.slice(0,3)+'-'+v.slice(3,7)+'-'+v.slice(7,11);
  else if(v.length>=4) v=v.slice(0,3)+'-'+v.slice(3);
  this.value=v;
});
</script>
