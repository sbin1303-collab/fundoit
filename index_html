<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>펀두잇파트너스 | 정책자금 무료 사전검토</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;900&family=Oswald:wght@600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --red:       #C0232A;
  --red-dark:  #8C1219;
  --red-light: #E8353D;
  --orange:    #E8650A;
  --orange-lt: #F28726;
  --black:     #0D0D0D;
  --black-2:   #171717;
  --black-3:   #222222;
  --white:     #FFFFFF;
  --off:       #F5F1EE;
  --gray:      #888888;
  --gray-lt:   #DDDDDD;
  --text:      #1A1A1A;
}

html{scroll-behavior:smooth}
body{font-family:'Noto Sans KR',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;line-height:1.6}

/* ── URGENCY BAR ── */
.urgency-bar{
  background:linear-gradient(90deg,var(--red-dark),var(--red),var(--orange),var(--red),var(--red-dark));
  background-size:300% 100%;
  animation:barShift 4s linear infinite;
  padding:10px 20px;
  text-align:center;
  font-size:13px;
  font-weight:700;
  letter-spacing:0.04em;
  color:var(--white);
  position:sticky;top:0;z-index:100;
}
@keyframes barShift{0%{background-position:0%}100%{background-position:300%}}

.urgency-bar span{
  display:inline-flex;align-items:center;gap:10px;
}
.blink{animation:blink 1s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

/* ── HERO ── */
.hero{
  position:relative;
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 440px;
  align-items:center;
  gap:60px;
  padding:70px 60px;
  max-width:1280px;
  margin:0 auto;
  overflow:hidden;
}

/* diagonal slash BG */
.hero::before{
  content:'';
  position:fixed;
  top:0;left:0;right:0;bottom:0;
  background:
    radial-gradient(ellipse 70% 60% at 30% 40%,rgba(192,35,42,0.18) 0%,transparent 65%),
    radial-gradient(ellipse 50% 40% at 80% 70%,rgba(232,101,10,0.1) 0%,transparent 60%);
  pointer-events:none;
  z-index:0;
}

.hero-left{position:relative;z-index:1;animation:fadeUp .7s ease both}
.hero-right{position:relative;z-index:1;animation:fadeUp .7s .15s ease both}

/* diagonal accent line */
.hero-left::before{
  content:'';
  position:absolute;
  top:-20px;left:-60px;
  width:4px;height:140%;
  background:linear-gradient(180deg,transparent,var(--red),var(--orange),transparent);
  transform:rotate(-3deg);
}

.eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  color:var(--orange-lt);
  margin-bottom:20px;
}
.eyebrow::before{content:'';width:28px;height:2px;background:var(--orange-lt)}

h1{
  font-family:'Oswald',sans-serif;
  font-size:clamp(36px,4.5vw,62px);
  font-weight:700;
  line-height:1.05;
  letter-spacing:-.01em;
  margin-bottom:20px;
  text-transform:uppercase;
}

h1 .line-normal{display:block;color:var(--white)}
h1 .line-accent{
  display:block;
  background:linear-gradient(90deg,var(--red-light),var(--orange));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
h1 .line-sub{display:block;color:var(--white);font-size:.55em;letter-spacing:.02em;margin-top:8px;font-family:'Noto Sans KR',sans-serif;font-weight:900;text-transform:none}

.hero-desc{
  font-size:16px;color:rgba(255,255,255,.55);
  margin-bottom:36px;line-height:1.75;max-width:480px;
}
.hero-desc strong{color:var(--white)}

/* stats strip */
.stats-strip{
  display:flex;gap:0;
  border:1px solid rgba(255,255,255,.08);
  border-radius:12px;
  overflow:hidden;
  margin-bottom:36px;
}
.stat{
  flex:1;padding:16px 14px;text-align:center;
  border-right:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.03);
  transition:background .2s;
}
.stat:last-child{border-right:none}
.stat:hover{background:rgba(192,35,42,.12)}

.stat-n{
  font-family:'Oswald',sans-serif;
  font-size:26px;font-weight:700;
  background:linear-gradient(90deg,var(--red-light),var(--orange-lt));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  line-height:1;margin-bottom:4px;
}
.stat-l{font-size:10px;color:rgba(255,255,255,.4);letter-spacing:.05em;font-weight:600;text-transform:uppercase}

/* trust pills */
.trust-row{display:flex;flex-wrap:wrap;gap:8px}
.trust-pill{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);
  border-radius:100px;padding:6px 14px;
  font-size:12px;font-weight:600;color:rgba(255,255,255,.7);
}
.trust-pill .dot{
  width:6px;height:6px;border-radius:50%;
  background:linear-gradient(135deg,var(--red-light),var(--orange));
  flex-shrink:0;
}

/* ── FORM CARD ── */
.form-card{
  background:var(--white);
  border-radius:16px;
  overflow:hidden;
  box-shadow:0 0 0 1px rgba(255,255,255,.08),0 40px 80px rgba(0,0,0,.6),0 0 80px rgba(192,35,42,.15);
}

.form-top{
  background:linear-gradient(135deg,var(--red-dark) 0%,var(--red) 50%,var(--orange) 100%);
  padding:20px 28px;
  position:relative;overflow:hidden;
}
.form-top::after{
  content:'';position:absolute;bottom:-1px;left:0;right:0;
  height:20px;background:var(--white);
  clip-path:ellipse(55% 100% at 50% 100%);
}

.form-top-title{
  font-family:'Oswald',sans-serif;
  font-size:20px;font-weight:700;color:var(--white);letter-spacing:.02em;
  text-transform:uppercase;margin-bottom:4px;
}
.form-top-sub{font-size:12px;color:rgba(255,255,255,.8);font-weight:500}

.form-body{padding:24px 28px 28px}

/* progress */
.prog-wrap{margin-bottom:24px}
.prog-steps{
  display:flex;justify-content:space-between;
  margin-bottom:10px;
}
.prog-dot{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  flex:1;
}
.prog-dot-circle{
  width:24px;height:24px;border-radius:50%;
  border:2px solid var(--gray-lt);
  background:var(--white);
  font-size:10px;font-weight:700;color:var(--gray);
  display:flex;align-items:center;justify-content:center;
  transition:all .3s;position:relative;z-index:1;
}
.prog-dot-circle.done{
  background:linear-gradient(135deg,var(--red),var(--orange));
  border-color:transparent;color:var(--white);
}
.prog-dot-circle.active{
  background:var(--white);border-color:var(--red);color:var(--red);
  box-shadow:0 0 0 3px rgba(192,35,42,.15);
}
.prog-dot-label{font-size:9px;color:var(--gray);font-weight:600;letter-spacing:.04em;text-transform:uppercase}
.prog-dot-label.active{color:var(--red);font-weight:700}

.prog-line{
  height:2px;background:var(--gray-lt);border-radius:99px;
  position:relative;margin-bottom:4px;
}
.prog-line-fill{
  position:absolute;top:0;left:0;height:100%;
  background:linear-gradient(90deg,var(--red),var(--orange));
  border-radius:99px;transition:width .4s cubic-bezier(.4,0,.2,1);
}

/* steps */
.step{display:none}
.step.active{display:block;animation:stepIn .3s ease both}
@keyframes stepIn{from{opacity:0;transform:translateX(10px)}to{opacity:1;transform:translateX(0)}}

.step-q{
  font-size:14px;font-weight:700;color:var(--text);
  margin-bottom:14px;line-height:1.4;
}
.step-q span{color:var(--red);font-size:11px;font-weight:600;display:block;margin-bottom:4px;letter-spacing:.04em;text-transform:uppercase}

.opts{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px}
.opts.col1{grid-template-columns:1fr}
.opts.col3{grid-template-columns:repeat(4,1fr)}

.opt{
  border:1.5px solid var(--gray-lt);
  background:var(--white);border-radius:10px;
  padding:11px 8px;
  font-size:13px;font-weight:600;color:var(--text);
  cursor:pointer;transition:all .18s;
  font-family:'Noto Sans KR',sans-serif;
  text-align:center;line-height:1.35;
}
.opt:hover{border-color:var(--red);color:var(--red);background:rgba(192,35,42,.04)}
.opt.sel{
  border-color:var(--red);background:linear-gradient(135deg,rgba(192,35,42,.08),rgba(232,101,10,.05));
  color:var(--red);box-shadow:0 0 0 3px rgba(192,35,42,.12);
}

/* inputs */
.inp-g{margin-bottom:12px}
.inp-l{display:block;font-size:11px;font-weight:700;color:var(--text);margin-bottom:5px;letter-spacing:.03em;text-transform:uppercase}
.inp{
  width:100%;border:1.5px solid var(--gray-lt);border-radius:9px;
  padding:13px 14px;font-size:15px;
  font-family:'Noto Sans KR',sans-serif;color:var(--text);
  outline:none;transition:border-color .2s,box-shadow .2s;background:var(--white);
}
.inp:focus{border-color:var(--red);box-shadow:0 0 0 3px rgba(192,35,42,.1)}

/* consent */
.consent{
  display:flex;align-items:flex-start;gap:9px;
  padding:11px;background:#FBF8F8;border-radius:8px;
  margin-bottom:16px;border:1px solid rgba(192,35,42,.1);
}
.consent input[type=checkbox]{width:15px;height:15px;margin-top:2px;accent-color:var(--red);flex-shrink:0;cursor:pointer}
.consent-txt{font-size:11px;color:var(--gray);line-height:1.5}
.consent-txt strong{color:var(--text)}

/* submit btn */
.submit-btn{
  width:100%;
  background:linear-gradient(135deg,var(--red-dark) 0%,var(--red) 40%,var(--orange) 100%);
  color:var(--white);border:none;border-radius:11px;
  padding:17px;font-size:16px;font-weight:900;
  font-family:'Noto Sans KR',sans-serif;
  cursor:pointer;transition:all .2s;
  letter-spacing:-.01em;position:relative;overflow:hidden;
  box-shadow:0 8px 24px rgba(192,35,42,.35);
}
.submit-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.15),transparent 60%);
  opacity:0;transition:opacity .2s;
}
.submit-btn:hover{transform:translateY(-2px);box-shadow:0 14px 32px rgba(192,35,42,.45)}
.submit-btn:hover::before{opacity:1}
.submit-btn:active{transform:translateY(0)}
.btn-sub-txt{font-size:11px;font-weight:400;opacity:.8;display:block;margin-top:3px}

/* phone alt */
.ph-alt{
  margin-top:14px;display:flex;align-items:center;justify-content:center;
  gap:10px;padding:12px;
  border:1.5px dashed rgba(192,35,42,.25);border-radius:10px;
  background:rgba(192,35,42,.03);
}
.ph-alt-l{font-size:11px;color:var(--gray);white-space:nowrap}
.ph-num{
  font-family:'Oswald',sans-serif;font-size:20px;font-weight:700;
  color:var(--red);text-decoration:none;letter-spacing:.04em;
  transition:color .2s;
}
.ph-num:hover{color:var(--orange)}

/* success */
.success{display:none;text-align:center;padding:16px 0;animation:fadeUp .5s ease both}
.success-ico{
  width:64px;height:64px;border-radius:50%;margin:0 auto 18px;
  background:linear-gradient(135deg,var(--red),var(--orange));
  display:flex;align-items:center;justify-content:center;
  font-size:26px;box-shadow:0 8px 28px rgba(192,35,42,.4);
}
.success-t{font-size:19px;font-weight:900;color:var(--text);margin-bottom:8px}
.success-d{font-size:13px;color:var(--gray);line-height:1.7;margin-bottom:18px}
.success-box{
  background:#FBF8F8;border-radius:10px;padding:16px;
  font-size:12px;color:var(--text);line-height:1.7;
  border:1px solid rgba(192,35,42,.1);
}

/* ── SECTIONS ── */
section{padding:80px 20px;position:relative}
.s-inner{max-width:1100px;margin:0 auto}

.s-tag{
  font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;
  color:var(--orange-lt);margin-bottom:12px;
}
.s-title{
  font-family:'Oswald',sans-serif;
  font-size:clamp(26px,3.5vw,44px);font-weight:700;
  line-height:1.1;margin-bottom:16px;letter-spacing:.01em;text-transform:uppercase;
  color:var(--white);
}
.s-title .r{color:var(--red-light)}
.s-desc{font-size:15px;color:rgba(255,255,255,.45);line-height:1.75;max-width:520px}

/* WHY */
.why-sec{background:var(--black-2)}
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
.why-card{
  background:var(--black-3);border-radius:14px;padding:28px 22px;
  border:1px solid rgba(255,255,255,.06);
  position:relative;overflow:hidden;transition:transform .2s,border-color .2s;
}
.why-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--red),var(--orange));
  transform:scaleX(0);transform-origin:left;transition:transform .3s;
}
.why-card:hover{transform:translateY(-4px);border-color:rgba(192,35,42,.3)}
.why-card:hover::after{transform:scaleX(1)}

.why-n{
  font-family:'Oswald',sans-serif;font-size:40px;font-weight:700;
  background:linear-gradient(135deg,rgba(192,35,42,.15),rgba(232,101,10,.1));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  line-height:1;margin-bottom:14px;
}
.why-t{font-size:17px;font-weight:800;color:var(--white);margin-bottom:10px;line-height:1.3}
.why-d{font-size:13px;color:rgba(255,255,255,.45);line-height:1.7}
.why-badge{
  display:inline-block;margin-top:12px;
  background:linear-gradient(135deg,rgba(192,35,42,.2),rgba(232,101,10,.15));
  border:1px solid rgba(192,35,42,.3);
  color:var(--orange-lt);font-size:11px;font-weight:700;
  padding:4px 10px;border-radius:4px;
}

/* CASES */
.cases-sec{background:var(--black)}

/* diagonal divider */
.diag-divider{
  height:60px;background:var(--black-2);
  clip-path:polygon(0 0,100% 0,100% 100%,0 40%);
  margin-bottom:-1px;
}

.cases-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.case-card{
  border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:22px;
  background:linear-gradient(135deg,rgba(192,35,42,.05),rgba(232,101,10,.03));
  transition:border-color .2s,transform .2s;
}
.case-card:hover{border-color:rgba(192,35,42,.35);transform:translateY(-3px)}

.case-ind{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--orange-lt);text-transform:uppercase;margin-bottom:10px}
.case-amt{
  font-family:'Oswald',sans-serif;font-size:28px;font-weight:700;
  background:linear-gradient(90deg,var(--red-light),var(--orange-lt));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:4px;line-height:1;
}
.case-ag{font-size:11px;color:rgba(255,255,255,.3);margin-bottom:12px}
.case-s{font-size:12px;color:rgba(255,255,255,.5);line-height:1.6;border-top:1px solid rgba(255,255,255,.07);padding-top:12px}

/* PROCESS */
.proc-sec{background:var(--black-2)}
.proc-wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:52px;position:relative}
.proc-wrap::after{
  content:'';position:absolute;
  top:30px;left:calc(12.5% + 12px);right:calc(12.5% + 12px);height:2px;
  background:linear-gradient(90deg,var(--red),var(--orange),var(--red));
}
.proc-item{text-align:center;padding:0 8px}
.proc-circle{
  width:60px;height:60px;border-radius:50%;margin:0 auto 16px;
  background:linear-gradient(135deg,var(--red-dark),var(--red),var(--orange));
  display:flex;align-items:center;justify-content:center;
  font-family:'Oswald',sans-serif;font-size:22px;font-weight:700;color:var(--white);
  position:relative;z-index:1;
  box-shadow:0 4px 20px rgba(192,35,42,.4);
}
.proc-t{font-size:14px;font-weight:800;color:var(--white);margin-bottom:8px}
.proc-d{font-size:12px;color:rgba(255,255,255,.4);line-height:1.6}

/* BOTTOM CTA */
.bot-cta{
  background:linear-gradient(135deg,var(--red-dark) 0%,var(--red) 50%,var(--orange) 100%);
  text-align:center;padding:90px 20px;position:relative;overflow:hidden;
}
.bot-cta::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 80% at 50% 50%,rgba(255,255,255,.07),transparent);
}

/* animated diagonal lines */
.bot-cta::after{
  content:'';position:absolute;inset:-50%;
  background:repeating-linear-gradient(
    -45deg,
    rgba(255,255,255,0) 0,rgba(255,255,255,0) 20px,
    rgba(255,255,255,.02) 20px,rgba(255,255,255,.02) 22px
  );
  animation:diag 20s linear infinite;
}
@keyframes diag{from{transform:translateX(0)}to{transform:translateX(44px)}}

.bot-inner{position:relative;z-index:1;max-width:640px;margin:0 auto}
.bot-tag{
  display:inline-block;background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.25);
  color:var(--white);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:5px 14px;border-radius:100px;margin-bottom:20px;
}
.bot-t{
  font-family:'Oswald',sans-serif;
  font-size:clamp(28px,4vw,48px);font-weight:700;
  color:var(--white);margin-bottom:14px;line-height:1.1;text-transform:uppercase;letter-spacing:.01em;
}
.bot-d{font-size:16px;color:rgba(255,255,255,.75);margin-bottom:36px;line-height:1.65}
.bot-btn{
  display:inline-block;
  background:var(--white);color:var(--red-dark);
  font-size:17px;font-weight:900;font-family:'Noto Sans KR',sans-serif;
  padding:18px 52px;border-radius:12px;border:none;
  cursor:pointer;text-decoration:none;
  transition:all .2s;letter-spacing:-.01em;
  box-shadow:0 8px 32px rgba(0,0,0,.3);
}
.bot-btn:hover{transform:translateY(-3px);box-shadow:0 16px 48px rgba(0,0,0,.4);background:var(--off)}

/* FOOTER */
footer{background:#080808;padding:36px 20px;text-align:center}
.ft-logo{
  font-family:'Oswald',sans-serif;font-size:18px;font-weight:700;
  background:linear-gradient(90deg,var(--red-light),var(--orange-lt));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:.08em;margin-bottom:12px;
}
.ft-info{font-size:11px;color:rgba(255,255,255,.2);line-height:1.9}

/* FLOATING */
.float-wrap{position:fixed;bottom:24px;right:24px;z-index:999;display:flex;flex-direction:column;align-items:flex-end;gap:8px}
.float-badge{
  background:var(--red);color:var(--white);
  font-size:11px;font-weight:700;padding:5px 12px;
  border-radius:100px;white-space:nowrap;
  box-shadow:0 4px 16px rgba(192,35,42,.5);
  animation:floatBadge 2s ease-in-out infinite alternate;
}
@keyframes floatBadge{from{transform:translateY(0)}to{transform:translateY(-4px)}}
.float-btn{
  width:58px;height:58px;border-radius:50%;
  background:linear-gradient(135deg,var(--red),var(--orange));
  display:flex;align-items:center;justify-content:center;font-size:24px;
  box-shadow:0 8px 28px rgba(192,35,42,.55);
  text-decoration:none;transition:transform .2s;
  animation:floatPulse 2s ease-in-out infinite;
}
.float-btn:hover{transform:scale(1.1)}
@keyframes floatPulse{
  0%,100%{box-shadow:0 8px 28px rgba(192,35,42,.55)}
  50%{box-shadow:0 8px 48px rgba(192,35,42,.8),0 0 0 8px rgba(192,35,42,.1)}
}

/* ANIMS */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* MOBILE */
@media(max-width:960px){
  .hero{grid-template-columns:1fr;padding:40px 20px 60px;gap:40px}
  .why-grid,.cases-grid{grid-template-columns:1fr}
  .proc-wrap{grid-template-columns:1fr 1fr;gap:32px}
  .proc-wrap::after{display:none}
}
@media(max-width:480px){
  .opts.col3{grid-template-columns:1fr 1fr}
  .proc-wrap{grid-template-columns:1fr}
  .stats-strip{flex-wrap:wrap}
  .stat{flex:1 0 40%}
  .form-body{padding:20px 18px 24px}
}
</style>
</head>
<body>

<!-- URGENCY BAR -->
<div class="urgency-bar">
